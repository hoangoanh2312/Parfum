NODE_ENV=development
PORT=5000

# So proxy tin cay dung truoc app (nginx/LB). Local de 1 hoac 0.
TRUST_PROXY=1

MONGO_URI=
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

CLIENT_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# Bao ve CSRF (double-submit). Mac dinh BAT. Chi dat 'false' neu that su can tat.
CSRF_ENABLED=true

# Redis cho rate limit phan tan khi chay NHIEU instance (tuy chon).
# Vi du: redis://localhost:6379
REDIS_URL=

# Sentry error tracking (tuy chon). Chi hoat dong khi da cai @sentry/node.
SENTRY_DSN=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=

# VietQR
VIETQR_BANK_BIN=
VIETQR_ACCOUNT_NO=
VIETQR_ACCOUNT_NAME=

# SePay webhook (HMAC-SHA256)
# Webhook URL: https://your-domain/api/payment-webhooks/sepay
SEPAY_WEBHOOK_SECRET=

# Admin bootstrap.
# Neu KHONG set ADMIN_BOOTSTRAP_PASSWORD + DEFAULT_ADMIN_EMAIL, he thong se KHONG tu tao admin
# (dung 'npm run create-admin' de tao thu cong mot cach an toan).
DEFAULT_ADMIN_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=
LEGACY_ADMIN_PASSWORD=

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="L'Essence Noire <your-email@gmail.com>"

# eSMS - gui OTP dat lai mat khau qua so dien thoai
ESMS_API_KEY=
ESMS_SECRET_KEY=
ESMS_BRAND_NAME=
ESMS_SMS_TYPE=2
ESMS_IS_UNICODE=0
ESMS_SANDBOX=0
ESMS_OTP_TEMPLATE={OTP} la ma dat lai mat khau L Essence Noire. Ma co hieu luc 5 phut.

# Chi dung local: khong gui SMS, OTP duoc in trong terminal cua server.
SMS_DEV_MODE=false
